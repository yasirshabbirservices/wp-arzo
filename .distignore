# Files excluded from the WordPress.org build (used by 10up/action-wordpress-plugin-deploy).
# Everything listed here is stripped from the SVN-deployed zip that wp.org hosts.

# Version control / CI
.git
.github
.gitignore
.gitattributes
.distignore

# AI / dev docs (never ship to .org — see the "no AI docs on public repo" rule)
.claude
CLAUDE.md
AI_RULES.md

# Tooling
bin
node_modules
build
scratchpad
*.map

# The in-plugin GitHub self-updater is forbidden on directory-hosted plugins:
# wp.org serves updates via SVN, so this file must not exist in the .org build.
# wp-arzo.php guards its require with file_exists(), so stripping it is safe.
includes/class-wp-arzo-updater.php

# "Disable All Updates" feature — hooks the update transients / auto-update
# filters, which Plugin Check flags as a forbidden update-modification. Stripped
# from the .org build; its registration in wp-arzo.php is file_exists()-guarded.
includes/features-registry/class-feature-disable-updates.php

# Standalone emergency-recovery tool. It deliberately bypasses WordPress (direct
# mysqli, PHP sessions, plugin-dir writes) so it can run when WP itself is broken —
# a design fundamentally incompatible with the WordPress.org guidelines and Plugin
# Check. Stripped from the .org build; remains in the self-hosted / GitHub / Pro
# build. All wiring is gated on wp_arzo_has_emergency_tool() (wp-arzo.php) + a
# file_exists() include guard (features/site-modes.php), so the .org build never
# exposes the endpoint or the Emergency Mode UI.
wp-arzo-emergency

# README.md and CHANGELOG.md are GitHub-facing docs (Pro upsell framing, full historical
# changelog including old entries about features long since moved to Pro). WordPress.org
# only reads README.txt — keeping these two out of the .org zip avoids any redundant,
# out-of-context, or promotional text being scanned as part of "the plugin description".
README.md
CHANGELOG.md
